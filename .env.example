# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME="FastAPI Next.js Template"
APP_ENV=local              # local | staging | production
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_KEY=                   # Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"

# =============================================================================
# DATABASE
# =============================================================================
DB_CONNECTION=mysql            # mysql | postgres
DB_HOST=db-mysql              # db-mysql | db-postgres
DB_PORT=3306                  # 3306 for mysql, 5432 for postgres
DB_FORWARD_PORT=3306          # change if local MySQL already uses 3306
DB_DATABASE=app
DB_USERNAME=appuser
DB_PASSWORD=               # Min 16 chars, use: make secrets
DB_ROOT_PASSWORD=          # Min 16 chars, use: make secrets

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET_KEY=            # Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15     # Short-lived for API calls
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30      # Longer-lived for persistence

# =============================================================================
# CORS & SECURITY
# =============================================================================
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000    # Comma-separated for multiple origins
NEXT_PUBLIC_API_URL=http://localhost:8000   # Backend API URL (used by Next.js client)

# =============================================================================
# SUPERUSER (Created on first migration/seed)
# =============================================================================
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=                     # Min 8 chars, use: make secrets

# =============================================================================
# MAIL (SMTP) — Leave MAIL_HOST empty to disable
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=                              # mailpit for local dev, leave empty to disable
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="FastAPI App"

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=debug            # debug | info | warning | error | critical
LOG_FORMAT=console         # json | console

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# TRAEFIK (Reverse Proxy)
# =============================================================================
TRAEFIK_DOMAIN=example.com
TRAEFIK_EMAIL=admin@example.com
TRAEFIK_DASHBOARD_USER=admin:           # Generate: htpasswd -nb admin password

# =============================================================================
# DOCKER IMAGES & DEPLOYMENT
# =============================================================================
DOCKER_IMAGE_BACKEND=ghcr.io/CHANGE_ME/backend
DOCKER_IMAGE_FRONTEND=ghcr.io/CHANGE_ME/frontend
IMAGE_TAG=latest
STACK_NAME=app

# =============================================================================
# STAGING/PRODUCTION ONLY (Do not set in .env, use CI/CD or secrets manager)
# =============================================================================
# DATABASE_URL=                     # Override DB connection string if needed
# REDIS_URL=                        # For caching/sessions (future)
# S3_BUCKET=                        # For file storage (future)
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
